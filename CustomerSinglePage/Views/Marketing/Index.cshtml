@{
    ViewData["Title"] = "Marketing Management";
}

<div class="container mt-4">
    <h2>Marketing Employee Form</h2>

    <form id="marketingForm">
        <input type="hidden" id="MarketingId" />

        <div class="row">
            <div class="col-md-4">
                <input type="text" id="Name" class="form-control" placeholder="Name" required />
            </div>
            <div class="col-md-4">
                <input type="text" id="Address" class="form-control" placeholder="Address" required />
            </div>
            <div class="col-md-3">
                <input type="text" id="Phone" class="form-control" placeholder="Phone" required />
            </div>
            <div class="col-md-2">
                <input type="color" id="Color" class="form-control form-control-color mt-2" />
            </div>
            <div class="d-flex justify-content-left mb-4 mt-3">
                <button type="submit" id="btnSave" class="btn btn-primary me-2">Save</button>
                <button type="button" class="btn btn-secondary" onclick="clearForm()">Clear</button>
            </div>
        </div>
    </form>
</div>

    <hr />

    <table class="table table-bordered mt-3">
        <thead>
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>Phone</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="marketingTable"></tbody>
    </table>

@section Scripts {
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

        <script>
            $(document).ready(function () {
                loadMarketings();
            });

            // Load all Marketings
            function loadMarketings() {
                $.get("/Marketing/GetAll", function (data) {
                    let rows = "";
                    data.forEach(m => {
                           rows += `<tr style="
               background-color:${m.color}15;
               border-left:6px solid ${m.color};
            ">
                                    <td>${m.name}</td>
                                    <td>${m.address}</td>
                                    <td>${m.phone}</td>
                                    <td>
                                        <button class="btn btn-warning btn-sm" onclick="editMarketing(${m.marketingId})" title="Edit">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-danger btn-sm" onclick="deleteMarketing(${m.marketingId})" title="Delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </td>
                                 </tr>`;
                    });
                    $("#marketingTable").html(rows);
                });
            }

            // Save / Update Marketing
            $("#marketingForm").submit(function (e) {
                e.preventDefault();

                           const marketing = {
                MarketingId: $("#MarketingId").val(),
                Name: $("#Name").val(),
                Address: $("#Address").val(),
                Phone: $("#Phone").val(),
                Color: $("#Color").val()   // 👈 ADD
            };

                $.post("/Marketing/Save", marketing, function () {

                    if ($("#MarketingId").val() > 0) {
                        Swal.fire('Updated!', 'Marketing updated successfully.', 'success');
                    } else {
                        Swal.fire('Saved!', 'Marketing saved successfully.', 'success');
                    }

                    clearForm();
                    loadMarketings();
                });
            });

            // Edit Marketing → Change button text
            function editMarketing(id) {
                $.get("/Marketing/GetMarketing/" + id, function (data) {
                    $("#MarketingId").val(data.marketingId);
                    $("#Name").val(data.name);
                    $("#Address").val(data.address);
                    $("#Phone").val(data.phone);
                    $("#Color").val(data.color);

                    $("#btnSave").text("Update").removeClass("btn-primary").addClass("btn-success");
                });
            }

            // Delete Marketing
            function deleteMarketing(id) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: "This marketing will be deleted!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Yes, delete!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post("/Marketing/Delete/" + id, function () {
                            Swal.fire('Deleted!', 'Marketing has been deleted.', 'success');
                            loadMarketings();
                        });
                    }
                });
            }

            // Clear form → reset button
            function clearForm() {
                $("#MarketingId").val('');
                $("#marketingForm")[0].reset();
                $("#btnSave").text("Save").removeClass("btn-success").addClass("btn-primary");
            }
        </script>
}
